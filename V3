import speech_recognition as sr
import google.generativeai as genai
import pyttsx3
import os

# 1. Setup Gemini AI
# Make sure your API Key is correct
genai.configure(api_key="AIzaSyCq6t0u99uJAW0uCT0a_Qp-fDpY3uhKwEM")
# Fixed: Added 'models/' prefix to avoid the 404 error
model = genai.GenerativeModel('models/gemini-1.5-flash')

# 2. Setup Voice (TTS)
engine = pyttsx3.init()
voices = engine.getProperty('voices')
engine.setProperty('rate', 150) # Speed of speech

def speak(text):
    print(f"Assistant: {text}")
    engine.say(text)
    engine.runAndWait()

def listen():
    recognizer = sr.Recognizer()
    # Using device_index=5 as identified in your hardware list
    with sr.Microphone(device_index=5) as source:
        print("\nListening...")
        # Reduced duration slightly for faster response
        recognizer.adjust_for_ambient_noise(source, duration=0.5)
        audio = recognizer.listen(source)

    try:
        query = recognizer.recognize_google(audio)
        print(f"You said: {query}")
        return query
    except Exception as e:
        # Returns None if it didn't hear anything clearly
        return None

# --- MAIN LOOP ---
speak("Hello! I am your Pi Assistant. How can I help you today?")

while True:
    user_input = listen()

    if user_input:
        # Check for exit commands
        if "exit" in user_input.lower() or "stop" in user_input.lower():
            speak("Goodbye!")
            break
        
        try:
            # Send the text to Gemini
            response = model.generate_content(user_input)
            # Speak the result back to you
            speak(response.text)
        except Exception as e:
            print(f"Gemini Error: {e}")
            speak("I'm having trouble thinking right now.")
